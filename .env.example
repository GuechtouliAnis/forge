# ==========================================
# FORGE ENV TEST FILE — # EDGE CASES
# ==========================================

# 1. plain unquoted, no comment
PLAIN=

# 2. unquoted with inline comment
UNQUOTED_COMMENT=  # this is a comment

# 3. unquoted, # with no space (still a comment per dotenv spec)
UNQUOTED_NOSPACE=  #comment

# 4. # in double quoted value
DOUBLE_QUOTED_HASH=

# 5. # in single quoted value
SINGLE_QUOTED_HASH=

# 6. double quoted with inline comment after
DOUBLE_QUOTED_COMMENT=  # this is a comment

# 7. single quoted with inline comment after
SINGLE_QUOTED_COMMENT=  # this is a comment

# 8. double quoted # in value AND inline comment after
DOUBLE_HASH_AND_COMMENT=  # this is a comment

# 9. single quoted # in value AND inline comment after
SINGLE_HASH_AND_COMMENT=  # this is a comment

# 10. multiple # in quoted value
MULTI_HASH=

# 11. multiple # in quoted value with comment
MULTI_HASH_COMMENT=  # another#hash#in#comment

# 12. value that looks like a real API key with #
API_KEY=

# 13. password with # mid value
DB_PASSWORD=

# 14. empty value
EMPTY_VALUE=

# 15. empty quoted value
EMPTY_DOUBLE=
EMPTY_SINGLE=

# 16. empty value with comment
EMPTY_WITH_COMMENT=  # no value here

# 17. # at very start of value unquoted
HASH_START=  #notacomment

# 18. escaped quote inside double quoted value
ESCAPED_QUOTE=

# 19. URL with # fragment
URL_HASH=  # production

# 20. just a # as the entire value
JUST_HASH=  #